   template<typename Rule, std::size_t SampleCount>
   cpf::complexity compute_generated_rule_complexity(const std::array<std::string_view, SampleCount>& inputs, std::string_view rule_name, std::size_t rule_id, std::size_t root_rule) {
      std::vector<std::tuple<std::string_view>> args;
      args.reserve(inputs.size());
      std::vector<double> arg_sizes;
      arg_sizes.reserve(inputs.size());
      for (const auto input : inputs) {
         args.emplace_back(input);
         arg_sizes.push_back(static_cast<double>(input.size()));
      }
      return cpf::complexity_of(
         [rule_name, rule_id, root_rule](std::string_view input) {
            auto result = cpf::detail::earley_recognize(input, grammar_spec, root_rule);
            if (!result.success) {
               throw std::runtime_error{"Generated complexity sample for rule '" + std::string{rule_name} + "' definition " + std::to_string(rule_id) + " failed to parse input: " + (result.error.has_value() ? result.error->message : std::string{"unknown parse failure"})};
            }
            return static_cast<std::size_t>(result.success);
         },
         std::move(args),
         std::move(arg_sizes));
   }
   std::unique_ptr<cpf::node> build_node(const parse_node_ptr& tree);

   template<typename T>
   std::unique_ptr<T> release_built_node_as(std::unique_ptr<cpf::node> built) {
      if (built == nullptr) {
         return nullptr;
      }
      auto* raw = dynamic_cast<T*>(built.get());
      if (raw == nullptr) {
         throw std::runtime_error{"Generated node cast failed"};
      }
      built.release();
      return std::unique_ptr<T>{raw};
   }


   int precedence_of_default_expr(const default_expr& node) {
      switch (node.rule_id()) {
         case default_add::RuleId: {
            const auto& value = static_cast<const default_add&>(node);
            switch (value.production_index) {
               case 0:
                  return 1;
               default:
                  return 0;
            }
         }
         case default_subtract::RuleId: {
            const auto& value = static_cast<const default_subtract&>(node);
            switch (value.production_index) {
               case 0:
                  return 2;
               default:
                  return 0;
            }
         }
         case default_multiply::RuleId: {
            const auto& value = static_cast<const default_multiply&>(node);
            switch (value.production_index) {
               case 0:
                  return 3;
               default:
                  return 0;
            }
         }
         default:
            return 0;
      }
   }

   bool validate_default_expr_child(const default_expr& child, int precedence, bool left_associative, bool is_left_child) {
      auto child_precedence = precedence_of_default_expr(child);
      if (child_precedence == 0) {
         return true;
      }
      if (child_precedence < precedence) {
         return false;
      }
      if (child_precedence > precedence) {
         return true;
      }
      return is_left_child ? left_associative : !left_associative;
   }

   [[maybe_unused]] bool validate_generated_node(const cpf::node& node) {
      switch (node.rule_id()) {
         case default_add::RuleId: {
            const auto& value = static_cast<const default_add&>(node);
            if (value.left && !validate_generated_node(*value.left)) {
               return false;
            }
            if (value.right && !validate_generated_node(*value.right)) {
               return false;
            }
            switch (value.production_index) {
               case 0:
                  if (value.left && !validate_default_expr_child(*value.left, 1, true, true)) {
                     return false;
                  }
                  if (value.right && !validate_default_expr_child(*value.right, 1, true, false)) {
                     return false;
                  }
                  break;
               default:
                  break;
            }
            return true;
         }
         case default_subtract::RuleId: {
            const auto& value = static_cast<const default_subtract&>(node);
            if (value.left && !validate_generated_node(*value.left)) {
               return false;
            }
            if (value.right && !validate_generated_node(*value.right)) {
               return false;
            }
            switch (value.production_index) {
               case 0:
                  if (value.left && !validate_default_expr_child(*value.left, 2, true, true)) {
                     return false;
                  }
                  if (value.right && !validate_default_expr_child(*value.right, 2, true, false)) {
                     return false;
                  }
                  break;
               default:
                  break;
            }
            return true;
         }
         case default_multiply::RuleId: {
            const auto& value = static_cast<const default_multiply&>(node);
            if (value.left && !validate_generated_node(*value.left)) {
               return false;
            }
            if (value.right && !validate_generated_node(*value.right)) {
               return false;
            }
            switch (value.production_index) {
               case 0:
                  if (value.left && !validate_default_expr_child(*value.left, 3, true, true)) {
                     return false;
                  }
                  if (value.right && !validate_default_expr_child(*value.right, 3, true, false)) {
                     return false;
                  }
                  break;
               default:
                  break;
            }
            return true;
         }
         case default_number::RuleId: {
            return true;
         }
         default:
            return true;
      }
   }

   std::unique_ptr<cpf::node> build_node(const parse_node_ptr& tree) {
      switch (tree->production) {
         case 0: {
            return build_node(cpf::detail::node_child_at(tree, 0));
         }
         case 1: {
            return build_node(cpf::detail::node_child_at(tree, 0));
         }
         case 2: {
            return build_node(cpf::detail::node_child_at(tree, 0));
         }
         case 3: {
            return build_node(cpf::detail::node_child_at(tree, 0));
         }
         case 4: {
            auto node = std::make_unique<default_add>();
            node->production_index = 0;
            node->range = tree->range;
            for (const auto& damage : tree->damage) {
               cpf::detail::add_damage(*node, damage);
            }
            auto child_0 = build_node(cpf::detail::node_child_at(tree, 0));
            node->left = release_built_node_as<default_expr>(std::move(child_0));
            node->op = cpf::detail::matched_child_at(tree, 1);
            auto child_2 = build_node(cpf::detail::node_child_at(tree, 2));
            node->right = release_built_node_as<default_expr>(std::move(child_2));
            return node;
         }
         case 5: {
            auto node = std::make_unique<default_subtract>();
            node->production_index = 0;
            node->range = tree->range;
            for (const auto& damage : tree->damage) {
               cpf::detail::add_damage(*node, damage);
            }
            auto child_0 = build_node(cpf::detail::node_child_at(tree, 0));
            node->left = release_built_node_as<default_expr>(std::move(child_0));
            node->op = cpf::detail::matched_child_at(tree, 1);
            auto child_2 = build_node(cpf::detail::node_child_at(tree, 2));
            node->right = release_built_node_as<default_expr>(std::move(child_2));
            return node;
         }
         case 6: {
            auto node = std::make_unique<default_multiply>();
            node->production_index = 0;
            node->range = tree->range;
            for (const auto& damage : tree->damage) {
               cpf::detail::add_damage(*node, damage);
            }
            auto child_0 = build_node(cpf::detail::node_child_at(tree, 0));
            node->left = release_built_node_as<default_expr>(std::move(child_0));
            node->op = cpf::detail::matched_child_at(tree, 1);
            auto child_2 = build_node(cpf::detail::node_child_at(tree, 2));
            node->right = release_built_node_as<default_expr>(std::move(child_2));
            return node;
         }
         case 7: {
            auto node = std::make_unique<default_number>();
            node->production_index = 0;
            node->range = tree->range;
            for (const auto& damage : tree->damage) {
               cpf::detail::add_damage(*node, damage);
            }
            node->value = cpf::detail::matched_child_at(tree, 0);
            return node;
         }
         default:
            throw std::runtime_error{"Unknown parse production"};
      }
   }

   template<typename T>
   cpf::recognize_result recognize_generated(const cpf::token_sequence& tokens, std::size_t root_rule) {
      cpf::recognize_result result;
      auto recognized = cpf::detail::earley_recognize(tokens, grammar_spec, root_rule);
      result.success = recognized.success;
      if (!recognized.success) {
         result.error = std::move(recognized.error);
      }
      return result;
   }

   template<typename T>
   cpf::recognize_result recognize_generated(std::string_view input, std::size_t root_rule) {
      auto tokens = cpf::detail::lex_input(input, grammar_spec);
      return recognize_generated<T>(tokens, root_rule);
   }

   template<typename T>
   cpf::parse_result<T> parse_generated(const cpf::token_sequence& tokens, std::size_t root_rule, const cpf::parse_options& options) {
      return cpf::detail::parse_shared_forest<T>(
         [&]() { return cpf::detail::earley_recognize(tokens, grammar_spec, root_rule); },
         [&](cpf::detail::forest_span_order order) {
            return cpf::detail::earley_parse(tokens, grammar_spec, root_rule, options.allow_partial, order);
         },
         grammar_model,
         root_rule,
         options,
         [](const parse_node_ptr& tree) { return cpf::detail::validate_parse_tree(tree, grammar_model); },
         [](const parse_node_ptr& tree) {
            auto built = build_node(tree);
            return release_built_node_as<T>(std::move(built));
         },
         [](const T& root, std::vector<const cpf::node*>& damaged_nodes) {
            visit_recursive(root, [&](auto& current) {
               if (current.is_damaged()) {
                  damaged_nodes.push_back(&current);
               }
            });
         });
   }

   template<typename T>
   cpf::parse_result<T> parse_generated(std::string_view input, std::size_t root_rule, const cpf::parse_options& options) {
      auto tokens = cpf::detail::lex_input(input, grammar_spec);
      return parse_generated<T>(tokens, root_rule, options);
   }

   cpf::parse_result<cpf::cst_node> parse_generated_cst(const cpf::token_sequence& tokens, std::size_t root_rule, const cpf::parse_options& options) {
      return cpf::detail::parse_shared_forest<cpf::cst_node>(
         [&]() { return cpf::detail::earley_recognize(tokens, grammar_spec, root_rule); },
         [&](cpf::detail::forest_span_order order) {
            return cpf::detail::earley_parse(tokens, grammar_spec, root_rule, options.allow_partial, order);
         },
         grammar_model,
         root_rule,
         options,
         [](const parse_node_ptr& tree) { return cpf::detail::validate_parse_tree(tree, grammar_model); },
         [](const parse_node_ptr& tree) { return cpf::detail::build_cst_node(tree, grammar_model); },
         [](const cpf::cst_node& root, std::vector<const cpf::node*>& damaged_nodes) {
            cpf::visit_cst_recursive(root, [&](const cpf::cst_node& current) {
               if (current.is_damaged()) {
                  damaged_nodes.push_back(&current);
               }
            });
         });
   }

   [[maybe_unused]] cpf::parse_result<cpf::cst_node> parse_generated_cst(std::string_view input, std::size_t root_rule, const cpf::parse_options& options) {
      auto tokens = cpf::detail::lex_input(input, grammar_spec);
      return parse_generated_cst(tokens, root_rule, options);
   }
} // namespace

auto detail::lex_default_attrs_generated(std::string_view input) -> cpf::token_sequence {
   return cpf::detail::lex_input(input, grammar_spec);
}

auto detail::parse_default_expr_default(std::string_view input, const cpf::parse_options& options) -> cpf::parse_result<default_expr> {
   auto tokens = detail::lex_default_attrs_generated(input);
   return parse_default_expr_default(tokens, options);
}

auto detail::parse_default_expr_cst(std::string_view input, const cpf::parse_options& options) -> cpf::parse_result<cpf::cst_node> {
   auto tokens = detail::lex_default_attrs_generated(input);
   return parse_default_expr_cst(tokens, options);
}

auto detail::parse_default_expr_default(const cpf::token_sequence& tokens, const cpf::parse_options& options) -> cpf::parse_result<default_expr> {
   return parse_generated<default_expr>(tokens, 0, options);
}

auto detail::parse_default_expr_cst(const cpf::token_sequence& tokens, const cpf::parse_options& options) -> cpf::parse_result<cpf::cst_node> {
   return parse_generated_cst(tokens, 0, options);
}

auto detail::recognize_default_expr_default(std::string_view input) -> cpf::recognize_result {
   auto tokens = detail::lex_default_attrs_generated(input);
   return recognize_default_expr_default(tokens);
}

auto detail::recognize_default_expr_default(const cpf::token_sequence& tokens) -> cpf::recognize_result {
   return recognize_generated<default_expr>(tokens, 0);
}

namespace {
   std::array<cpf::complexity, 4> default_expr_complexity_cache{};
} // namespace

auto detail::complexity_inputs_default_expr_default(std::size_t production_index) -> std::span<const std::string_view> {
   switch (production_index) {
      case 0:
         return std::span<const std::string_view>{default_expr_complexity_inputs_0.data(), default_expr_complexity_inputs_0.size()};
      case 1:
         return std::span<const std::string_view>{default_expr_complexity_inputs_1.data(), default_expr_complexity_inputs_1.size()};
      case 2:
         return std::span<const std::string_view>{default_expr_complexity_inputs_2.data(), default_expr_complexity_inputs_2.size()};
      case 3:
         return std::span<const std::string_view>{default_expr_complexity_inputs_3.data(), default_expr_complexity_inputs_3.size()};
      default:
         throw std::out_of_range{"Unknown production index " + std::to_string(production_index) + " for rule 'default_expr'"};
   }
}

auto detail::complexity_default_expr_default(std::size_t production_index) -> const cpf::complexity& {
   switch (production_index) {
      case 0:
         return default_expr_complexity_cache[0];
      case 1:
         return default_expr_complexity_cache[1];
      case 2:
         return default_expr_complexity_cache[2];
      case 3:
         return default_expr_complexity_cache[3];
      default:
         throw std::out_of_range{"Unknown production index " + std::to_string(production_index) + " for rule 'default_expr'"};
   }
}

auto detail::recompute_complexity_default_expr_default(std::size_t production_index) -> const cpf::complexity& {
   switch (production_index) {
      case 0:
         default_expr_complexity_cache[0] = compute_generated_rule_complexity<default_expr>(default_expr_complexity_inputs_0, "default_expr", 0, 0);
         return default_expr_complexity_cache[0];
      case 1:
         default_expr_complexity_cache[1] = compute_generated_rule_complexity<default_expr>(default_expr_complexity_inputs_1, "default_expr", 1, 0);
         return default_expr_complexity_cache[1];
      case 2:
         default_expr_complexity_cache[2] = compute_generated_rule_complexity<default_expr>(default_expr_complexity_inputs_2, "default_expr", 2, 0);
         return default_expr_complexity_cache[2];
      case 3:
         default_expr_complexity_cache[3] = compute_generated_rule_complexity<default_expr>(default_expr_complexity_inputs_3, "default_expr", 3, 0);
         return default_expr_complexity_cache[3];
      default:
         throw std::out_of_range{"Unknown production index " + std::to_string(production_index) + " for rule 'default_expr'"};
   }
}

auto detail::parse_default_add_default(std::string_view input, const cpf::parse_options& options) -> cpf::parse_result<default_add> {
