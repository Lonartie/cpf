template<typename TargetUserData, typename SourceUserData>
auto rebind_default_expr_node(const default_expr_node<SourceUserData>& node) -> std::unique_ptr<default_expr_node<TargetUserData>>;

template<typename TargetUserData, typename SourceUserData>
auto rebind_default_add_node(const default_add_node<SourceUserData>& node) -> std::unique_ptr<default_add_node<TargetUserData>>;

template<typename TargetUserData, typename SourceUserData>
auto rebind_default_subtract_node(const default_subtract_node<SourceUserData>& node) -> std::unique_ptr<default_subtract_node<TargetUserData>>;

template<typename TargetUserData, typename SourceUserData>
auto rebind_default_multiply_node(const default_multiply_node<SourceUserData>& node) -> std::unique_ptr<default_multiply_node<TargetUserData>>;

template<typename TargetUserData, typename SourceUserData>
auto rebind_default_number_node(const default_number_node<SourceUserData>& node) -> std::unique_ptr<default_number_node<TargetUserData>>;

template<typename TargetUserData, typename SourceUserData>
auto rebind_default_expr_node(const default_expr_node<SourceUserData>& node) -> std::unique_ptr<default_expr_node<TargetUserData>> {
   switch (node.rule_id()) {
      case default_add_node<SourceUserData>::RuleId:
         return rebind_default_add_node<TargetUserData>(static_cast<const default_add_node<SourceUserData>&>(node));
      case default_subtract_node<SourceUserData>::RuleId:
         return rebind_default_subtract_node<TargetUserData>(static_cast<const default_subtract_node<SourceUserData>&>(node));
      case default_multiply_node<SourceUserData>::RuleId:
         return rebind_default_multiply_node<TargetUserData>(static_cast<const default_multiply_node<SourceUserData>&>(node));
      case default_number_node<SourceUserData>::RuleId:
         return rebind_default_number_node<TargetUserData>(static_cast<const default_number_node<SourceUserData>&>(node));
      default:
         throw std::bad_cast{};
   }
}

template<typename TargetUserData, typename SourceUserData>
auto rebind_default_add_node(const default_add_node<SourceUserData>& node) -> std::unique_ptr<default_add_node<TargetUserData>> {
   auto copy = std::make_unique<default_add_node<TargetUserData>>();
   copy->production_index = node.production_index;
   copy->range = node.range;
   for (const auto& damage : node.damage()) {
      cpf::detail::add_damage(*copy, damage);
   }
   if constexpr (!std::is_void_v<TargetUserData> && !std::is_void_v<SourceUserData>) {
      copy->user_data = node.user_data;
   }
   copy->left = node.left ? detail::rebind_default_expr_node<TargetUserData>(*node.left) : nullptr;
   copy->op = node.op;
   copy->right = node.right ? detail::rebind_default_expr_node<TargetUserData>(*node.right) : nullptr;
   return copy;
}

template<typename TargetUserData, typename SourceUserData>
auto rebind_default_subtract_node(const default_subtract_node<SourceUserData>& node) -> std::unique_ptr<default_subtract_node<TargetUserData>> {
   auto copy = std::make_unique<default_subtract_node<TargetUserData>>();
   copy->production_index = node.production_index;
   copy->range = node.range;
   for (const auto& damage : node.damage()) {
      cpf::detail::add_damage(*copy, damage);
   }
   if constexpr (!std::is_void_v<TargetUserData> && !std::is_void_v<SourceUserData>) {
      copy->user_data = node.user_data;
   }
   copy->left = node.left ? detail::rebind_default_expr_node<TargetUserData>(*node.left) : nullptr;
   copy->op = node.op;
   copy->right = node.right ? detail::rebind_default_expr_node<TargetUserData>(*node.right) : nullptr;
   return copy;
}

template<typename TargetUserData, typename SourceUserData>
auto rebind_default_multiply_node(const default_multiply_node<SourceUserData>& node) -> std::unique_ptr<default_multiply_node<TargetUserData>> {
   auto copy = std::make_unique<default_multiply_node<TargetUserData>>();
   copy->production_index = node.production_index;
   copy->range = node.range;
   for (const auto& damage : node.damage()) {
      cpf::detail::add_damage(*copy, damage);
   }
   if constexpr (!std::is_void_v<TargetUserData> && !std::is_void_v<SourceUserData>) {
      copy->user_data = node.user_data;
   }
   copy->left = node.left ? detail::rebind_default_expr_node<TargetUserData>(*node.left) : nullptr;
   copy->op = node.op;
   copy->right = node.right ? detail::rebind_default_expr_node<TargetUserData>(*node.right) : nullptr;
   return copy;
}

template<typename TargetUserData, typename SourceUserData>
auto rebind_default_number_node(const default_number_node<SourceUserData>& node) -> std::unique_ptr<default_number_node<TargetUserData>> {
   auto copy = std::make_unique<default_number_node<TargetUserData>>();
   copy->production_index = node.production_index;
   copy->range = node.range;
   for (const auto& damage : node.damage()) {
      cpf::detail::add_damage(*copy, damage);
   }
   if constexpr (!std::is_void_v<TargetUserData> && !std::is_void_v<SourceUserData>) {
      copy->user_data = node.user_data;
   }
   copy->value = node.value;
   return copy;
}

} // namespace detail

template<typename UserData>
auto default_expr_node<UserData>::lex(std::string_view input) -> cpf::token_sequence {
   return detail::lex_default_attrs_generated(input);
}

template<typename UserData>
auto default_expr_node<UserData>::parse_cst(std::string_view input, const cpf::parse_options& options) -> cst_parse_result {
   return detail::parse_default_expr_cst(input, options);
}

template<typename UserData>
auto default_expr_node<UserData>::parse_cst(const cpf::token_sequence& tokens, const cpf::parse_options& options) -> cst_parse_result {
   return detail::parse_default_expr_cst(tokens, options);
}

template<typename UserData>
auto default_expr_node<UserData>::parse(std::string_view input, const cpf::parse_options& options) -> parse_result {
   if constexpr (std::is_void_v<UserData>) {
      return detail::parse_default_expr_default(input, options);
   } else {
      auto default_result = detail::parse_default_expr_default(input, options);
      parse_result converted;
      converted.status = default_result.status;
      converted.success = default_result.success;
      converted.partial = default_result.partial;
      converted.error = std::move(default_result.error);
      if (!options.build_ast) {
         return converted;
      }
      converted.forest.reserve(default_result.forest.size());
      for (const auto& tree : default_result.forest) {
         auto materialized = tree.get();
         converted.forest.emplace_back(materialized != nullptr ? detail::rebind_default_expr_node<UserData>(*materialized) : nullptr);
      }
      return converted;
   }
}

template<typename UserData>
auto default_expr_node<UserData>::parse(const cpf::token_sequence& tokens, const cpf::parse_options& options) -> parse_result {
   if constexpr (std::is_void_v<UserData>) {
      return detail::parse_default_expr_default(tokens, options);
   } else {
      auto default_result = detail::parse_default_expr_default(tokens, options);
      parse_result converted;
      converted.status = default_result.status;
      converted.success = default_result.success;
      converted.partial = default_result.partial;
      converted.error = std::move(default_result.error);
      if (!options.build_ast) {
         return converted;
      }
      converted.forest.reserve(default_result.forest.size());
      for (const auto& tree : default_result.forest) {
         auto materialized = tree.get();
         converted.forest.emplace_back(materialized != nullptr ? detail::rebind_default_expr_node<UserData>(*materialized) : nullptr);
      }
      return converted;
   }
}

