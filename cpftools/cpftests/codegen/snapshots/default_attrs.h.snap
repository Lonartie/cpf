void visit_recursive(const default_expr_node<UserData>& node, Visitor&& visitor) {
   visit_recursive(node, std::forward<Visitor>(visitor), static_cast<const cpf::node*>(nullptr));
}

template<typename UserData, typename Visitor, typename Parent>
void visit_recursive(const default_expr_node<UserData>& node, Visitor&& visitor, const Parent* parent) {
   switch (node.rule_id()) {
      case default_add_node<UserData>::RuleId:
         visit_recursive(static_cast<const default_add_node<UserData>&>(node), visitor, parent);
         return;
      case default_subtract_node<UserData>::RuleId:
         visit_recursive(static_cast<const default_subtract_node<UserData>&>(node), visitor, parent);
         return;
      case default_multiply_node<UserData>::RuleId:
         visit_recursive(static_cast<const default_multiply_node<UserData>&>(node), visitor, parent);
         return;
      case default_number_node<UserData>::RuleId:
         visit_recursive(static_cast<const default_number_node<UserData>&>(node), visitor, parent);
