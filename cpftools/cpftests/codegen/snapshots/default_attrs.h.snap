template<typename UserData>
std::ostream& operator<<(std::ostream& os, const default_expr_node<UserData>& node) {
   switch (node.rule_id()) {
      case default_add_node<UserData>::RuleId:
         return os << static_cast<const default_add_node<UserData>&>(node);
      case default_subtract_node<UserData>::RuleId:
         return os << static_cast<const default_subtract_node<UserData>&>(node);
      case default_multiply_node<UserData>::RuleId:
         return os << static_cast<const default_multiply_node<UserData>&>(node);
      case default_number_node<UserData>::RuleId:
         return os << static_cast<const default_number_node<UserData>&>(node);
      default:
         return os << "default_expr()";
   }
}

