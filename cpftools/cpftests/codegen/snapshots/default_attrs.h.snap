template<typename UserData, typename Visitor>
auto visit(const default_expr_node<UserData>& node, Visitor&& visitor) {
   switch (node.rule_id()) {
      case default_add_node<UserData>::RuleId:
         return visit(static_cast<const default_add_node<UserData>&>(node), visitor);
      case default_subtract_node<UserData>::RuleId:
         return visit(static_cast<const default_subtract_node<UserData>&>(node), visitor);
      case default_multiply_node<UserData>::RuleId:
         return visit(static_cast<const default_multiply_node<UserData>&>(node), visitor);
      case default_number_node<UserData>::RuleId:
         return visit(static_cast<const default_number_node<UserData>&>(node), visitor);
      default:
         throw std::bad_cast{};
   }
}

