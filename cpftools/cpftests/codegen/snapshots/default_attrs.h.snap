namespace detail {

template<typename Node, typename Parent, typename Visitor>
void invoke_default_attrs_recursive_visitor(Node& node, Parent* parent, Visitor&& visitor) {
   if constexpr (std::is_invocable_v<Visitor&&, Node&, Parent*>) {
      std::forward<Visitor>(visitor)(node, parent);
   } else {
      std::forward<Visitor>(visitor)(node);
   }
}

inline void write_default_attrs_debug_indent(std::ostream& os, std::size_t indent) {
   for (std::size_t i = 0; i < indent; ++i) {
      os << "  ";
   }
}

inline void write_default_attrs_debug_block(std::ostream& os, std::string block, std::size_t indent) {
   if (block.empty()) {
      write_default_attrs_debug_indent(os, indent);
      return;
   }
   for (;;) {
      const auto line_end = block.find('\n');
      write_default_attrs_debug_indent(os, indent);
      os << block.substr(0, line_end);
      if (line_end == std::string::npos) {
         break;
      }
      os << '\n';
      block.erase(0, line_end + 1);
      if (block.empty()) {
         write_default_attrs_debug_indent(os, indent);
         break;
      }
   }
}

