label_expr -> label_times | label_divide | label_plus | label_minus | label_number;
label_times  [prec > 'sum', lbl = 'product'] -> label_expr:left '*':op label_expr:right;
label_divide [prec = 'product']              -> label_expr:left '/':op label_expr:right;
label_plus   [prec < 'product', lbl = 'sum'] -> label_expr:left '+':op label_expr:right;
label_minus  [prec = 'sum']                  -> label_expr:left '-':op label_expr:right;
label_number [lbl = 'atom']                  -> r'[0-9]+':value;

