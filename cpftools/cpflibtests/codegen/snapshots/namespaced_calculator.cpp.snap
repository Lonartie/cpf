                        }
                     });
                  }, [opaque](std::string_view repaired_input) { return cpf::detail::repaired_input_of(opaque, repaired_input, grammar_spec); });
               }
            }
         }
      } else if (!have_error) {
         best_error = *child_result.error;
         have_error = true;
      } else {
         cpf::detail::merge_parse_error(best_error, *child_result.error);
      }
   }
   if (result.success) {
      return result;
   }
   if (have_error) {
      cpf::detail::append_unique(best_error.notes, "while matching base rule 'expression'");
      cpf::detail::error_tracker::finalize(best_error);
      result.error = best_error;
   }
