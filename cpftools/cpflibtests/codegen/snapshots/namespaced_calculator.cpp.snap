   }};
   constexpr cpf::detail::grammar_spec grammar_spec{grammar_productions.data(), grammar_productions.size(), 3, grammar_rule_expected_labels.data(), grammar_rule_production_indices.data(), grammar_rule_production_offsets.data(), grammar_rule_production_counts.data(), grammar_token_symbols.data(), grammar_token_symbols.size(), grammar_skip_symbols.data(), grammar_skip_symbols.size(), false};
