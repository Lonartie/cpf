   template<typename Rule, std::size_t SampleCount>
   cpf::complexity compute_generated_rule_complexity(const std::array<std::string_view, SampleCount>& inputs, std::string_view rule_name, std::size_t rule_id, std::size_t root_rule) {
      std::vector<std::tuple<std::string_view>> args;
      args.reserve(inputs.size());
      std::vector<double> arg_sizes;
      arg_sizes.reserve(inputs.size());
      for (const auto input : inputs) {
         args.emplace_back(input);
         arg_sizes.push_back(static_cast<double>(input.size()));
      }
      return cpf::complexity_of(
         [rule_name, rule_id, root_rule](std::string_view input) {
            auto result = cpf::detail::earley_recognize(input, grammar_spec, root_rule);
            if (!result.success) {
               throw std::runtime_error{"Generated complexity sample for rule '" + std::string{rule_name} + "' definition " + std::to_string(rule_id) + " failed to parse input: " + (result.error.has_value() ? result.error->message : std::string{"unknown parse failure"})};
            }
            return static_cast<std::size_t>(result.success);
         },
         std::move(args),
         std::move(arg_sizes));
   }
   std::unique_ptr<cpf::node> build_node(const parse_node_ptr& tree);
   std::unique_ptr<cpf::cst_node> build_cst_node(const parse_node_ptr& tree);
   void append_cst_children(const parse_node_ptr& tree, std::vector<cpf::cst_child>& children);

   template<typename T>
   std::unique_ptr<T> release_built_node_as(std::unique_ptr<cpf::node> built) {
      if (built == nullptr) {
         return nullptr;
      }
      auto* raw = dynamic_cast<T*>(built.get());
      if (raw == nullptr) {
         throw std::runtime_error{"Generated node cast failed"};
      }
      built.release();
      return std::unique_ptr<T>{raw};
   }

   parse_node_ptr node_child_at(const parse_node_ptr& tree, std::size_t index) {
      if (index >= tree->children.size()) {
         throw std::runtime_error{"Generated parse tree missing node child"};
      }
      const auto* child = std::get_if<parse_node_ptr>(&tree->children[index]);
      if (child == nullptr || *child == nullptr) {
         throw std::runtime_error{"Generated parse tree child is not a node"};
      }
      return *child;
   }

   cpf::matched_string matched_child_at(const parse_node_ptr& tree, std::size_t index) {
      if (index >= tree->children.size()) {
         throw std::runtime_error{"Generated parse tree missing terminal child"};
      }
      const auto* child = std::get_if<cpf::matched_string>(&tree->children[index]);
      if (child == nullptr) {
         throw std::runtime_error{"Generated parse tree child is not a terminal"};
      }
      return *child;
   }

   [[maybe_unused]] void append_matched_tree_text(const parse_node_ptr& tree, std::string& text) {
      for (const auto& child : tree->children) {
         if (const auto* matched = std::get_if<cpf::matched_string>(&child); matched != nullptr) {
            text += matched->text;
            continue;
         }
         const auto* node = std::get_if<parse_node_ptr>(&child);
         if (node == nullptr || *node == nullptr) {
            throw std::runtime_error{"Generated parse tree child is not materializable as token text"};
         }
         append_matched_tree_text(*node, text);
      }
   }

   [[maybe_unused]] cpf::matched_string matched_tree_at(const parse_node_ptr& tree) {
      cpf::matched_string matched;
      matched.range = tree->range;
      append_matched_tree_text(tree, matched.text);
      return matched;
   }

   bool generated_tree_is_synthetic(const parse_node_ptr& tree) {
      switch (tree->production) {
         case 0:
            return false;
         case 1:
            return false;
         case 2:
            return false;
         case 3:
            return false;
         default:
            return false;
      }
   }

   std::size_t generated_tree_rule_id(const parse_node_ptr& tree) {
      switch (tree->production) {
         case 0:
            return expression::RuleId;
         case 1:
            return expression::RuleId;
         case 2:
            return addition::RuleId;
         case 3:
            return number::RuleId;
         default:
            throw std::runtime_error{"Unknown parse production"};
      }
   }

   std::string_view generated_tree_rule_name(const parse_node_ptr& tree) {
      switch (tree->production) {
         case 0:
            return "expression";
         case 1:
            return "expression";
         case 2:
            return "addition";
         case 3:
            return "number";
         default:
            throw std::runtime_error{"Unknown parse production"};
      }
   }

   void append_cst_children(const parse_node_ptr& tree, std::vector<cpf::cst_child>& children) {
      for (const auto& child : tree->children) {
         if (const auto* matched = std::get_if<cpf::matched_string>(&child); matched != nullptr) {
            children.emplace_back(*matched);
            continue;
         }
         const auto* node = std::get_if<parse_node_ptr>(&child);
         if (node == nullptr || *node == nullptr) {
            throw std::runtime_error{"Generated parse tree child is not a node"};
         }
         if (generated_tree_is_synthetic(*node)) {
            append_cst_children(*node, children);
            continue;
         }
         children.emplace_back(build_cst_node(*node));
      }
   }


   std::size_t definition_of_generated_tree(const parse_node_ptr& tree) {
      switch (tree->production) {
         case 0:
            return 0;
         case 1:
            return 1;
         case 2:
            return 0;
         case 3:
            return 0;
         default:
            return 0;
      }
   }

   int precedence_of_expression(const expression& node) {
      switch (node.rule_id()) {
         case addition::RuleId: {
            const auto& value = static_cast<const addition&>(node);
            switch (value.production_index) {
               case 0:
                  return 1;
               default:
                  return 0;
            }
         }
         default:
            return 0;
      }
   }

   bool validate_expression_child(const expression& child, int precedence, bool left_associative, bool is_left_child) {
      auto child_precedence = precedence_of_expression(child);
      if (child_precedence == 0) {
         return true;
      }
      if (child_precedence < precedence) {
         return false;
      }
      if (child_precedence > precedence) {
         return true;
      }
      return is_left_child ? left_associative : !left_associative;
   }

   int precedence_of_expression_tree(const parse_node_ptr& tree) {
      switch (tree->production) {
         case 0:
            return precedence_of_expression_tree(node_child_at(tree, 0));
         case 1:
            return precedence_of_expression_tree(node_child_at(tree, 0));
         case 2:
            return 1;
         default:
            return 0;
      }
   }

   bool validate_expression_child_tree(const parse_node_ptr& child, int precedence, bool left_associative, bool is_left_child) {
      auto child_precedence = precedence_of_expression_tree(child);
      if (child_precedence == 0) {
         return true;
      }
      if (child_precedence < precedence) {
         return false;
      }
      if (child_precedence > precedence) {
         return true;
      }
      return is_left_child ? left_associative : !left_associative;
   }

   [[maybe_unused]] bool validate_generated_node(const cpf::node& node) {
      switch (node.rule_id()) {
         case addition::RuleId: {
            const auto& value = static_cast<const addition&>(node);
            if (value.left && !validate_generated_node(*value.left)) {
               return false;
            }
            if (value.right && !validate_generated_node(*value.right)) {
               return false;
            }
            switch (value.production_index) {
               case 0:
                  if (value.left && !validate_expression_child(*value.left, 1, true, true)) {
                     return false;
                  }
                  if (value.right && !validate_expression_child(*value.right, 1, true, false)) {
                     return false;
                  }
                  break;
               default:
                  break;
            }
            return true;
         }
         case number::RuleId: {
            return true;
         }
         default:
            return true;
      }
   }

   bool validate_generated_tree(const parse_node_ptr& tree) {
      for (const auto& child : tree->children) {
         if (std::holds_alternative<parse_node_ptr>(child) && !validate_generated_tree(std::get<parse_node_ptr>(child))) {
            return false;
         }
      }
      switch (tree->production) {
         case 0: {
            return true;
         }
         case 1: {
            return true;
         }
         case 2: {
            if (!validate_expression_child_tree(node_child_at(tree, 0), 1, true, true)) {
               return false;
            }
            if (!validate_expression_child_tree(node_child_at(tree, 2), 1, true, false)) {
               return false;
            }
            return true;
         }
         case 3: {
            return true;
         }
         default:
            return true;
      }
   }

   std::unique_ptr<cpf::node> build_node(const parse_node_ptr& tree) {
      switch (tree->production) {
         case 0: {
            return build_node(node_child_at(tree, 0));
         }
         case 1: {
            return build_node(node_child_at(tree, 0));
         }
         case 2: {
            auto node = std::make_unique<addition>();
            node->production_index = 0;
            node->range = tree->range;
            for (const auto& damage : tree->damage) {
               cpf::detail::add_damage(*node, damage);
            }
            auto child_0 = build_node(node_child_at(tree, 0));
            node->left = release_built_node_as<expression>(std::move(child_0));
            node->op = matched_child_at(tree, 1);
            auto child_2 = build_node(node_child_at(tree, 2));
            node->right = release_built_node_as<expression>(std::move(child_2));
            return node;
         }
         case 3: {
            auto node = std::make_unique<number>();
            node->production_index = 0;
            node->range = tree->range;
            for (const auto& damage : tree->damage) {
               cpf::detail::add_damage(*node, damage);
            }
            node->value = matched_child_at(tree, 0);
            return node;
         }
         default:
            throw std::runtime_error{"Unknown parse production"};
      }
   }

   std::unique_ptr<cpf::cst_node> build_cst_node(const parse_node_ptr& tree) {
      auto node = std::make_unique<cpf::cst_node>();
      node->production_index = definition_of_generated_tree(tree);
      node->range = tree->range;
      node->rule = generated_tree_rule_id(tree);
      node->rule_name = std::string{generated_tree_rule_name(tree)};
      for (const auto& damage : tree->damage) {
         cpf::detail::add_damage(*node, damage);
      }
      append_cst_children(tree, node->children);
      return node;
   }

   template<typename T>
   cpf::recognize_result recognize_generated(const cpf::token_sequence& tokens, std::size_t root_rule) {
      cpf::recognize_result result;
      auto recognized = cpf::detail::earley_recognize(tokens, grammar_spec, root_rule);
      result.success = recognized.success;
      if (!recognized.success) {
         result.error = std::move(recognized.error);
      }
      return result;
   }

   template<typename T>
   cpf::recognize_result recognize_generated(std::string_view input, std::size_t root_rule) {
      auto tokens = cpf::detail::lex_input(input, grammar_spec);
      return recognize_generated<T>(tokens, root_rule);
   }

   template<typename T>
   cpf::parse_result<T> parse_generated(const cpf::token_sequence& tokens, std::size_t root_rule, const cpf::parse_options& options) {
      cpf::parse_result<T> result;
      auto forest = cpf::detail::earley_parse(tokens, grammar_spec, root_rule, options.allow_partial);
      if (!forest.success) {
         result.error = std::move(forest.error);
         return result;
      }
      result.partial = forest.partial;
      if (result.partial) {
         result.error = forest.error;
      }
      auto valid_tree_count = std::size_t{0};
      for (std::size_t tree_index = 0; tree_index < forest.forest.size(); ++tree_index) {
         const auto& tree = forest.forest[tree_index];
         if (!validate_generated_tree(tree)) {
            continue;
         }
         ++valid_tree_count;
         if (options.error_on_ambiguity && valid_tree_count > 1) {
            result.status = cpf::parse_status::failure;
            result.success = false;
            result.forest.clear();
            result.error = cpf::detail::make_ambiguity_error(grammar_rule_names[root_rule]);
            return result;
         }
         result.status = result.partial ? cpf::parse_status::partial_success : cpf::parse_status::success;
         result.success = true;
         if (options.build_ast) {
            result.forest.emplace_back(tree, definition_of_generated_tree(tree), tree->range, [tree]() {
               auto built = build_node(tree);
               return release_built_node_as<T>(std::move(built));
            }, forest.tree_damage[tree_index], forest.tree_partial[tree_index], [](const T& root, std::vector<const cpf::node*>& damaged_nodes) {
               visit_recursive(root, [&](auto& current) {
                  if (current.is_damaged()) {
                     damaged_nodes.push_back(&current);
                  }
               });
            }, [tree](std::string_view repaired_input) { return cpf::detail::repaired_input_of(tree, repaired_input, grammar_spec); });
         }
      }
      if (result.success) {
         return result;
      }
      auto filtered_error = cpf::parse_error{};
      filtered_error.expected.push_back("valid parse tree");
      filtered_error.found.kind = cpf::parse_error_found_kind::filtered_parse;
      filtered_error.notes.push_back(std::string{R"(completed Earley parses for rule ')"} + std::string{grammar_rule_names[root_rule]} + R"(' were rejected by precedence/associativity constraints)");
      cpf::detail::error_tracker::finalize(filtered_error);
      result.error = std::move(filtered_error);
      return result;
   }

   template<typename T>
   cpf::parse_result<T> parse_generated(std::string_view input, std::size_t root_rule, const cpf::parse_options& options) {
      auto tokens = cpf::detail::lex_input(input, grammar_spec);
      return parse_generated<T>(tokens, root_rule, options);
   }

   cpf::parse_result<cpf::cst_node> parse_generated_cst(const cpf::token_sequence& tokens, std::size_t root_rule, const cpf::parse_options& options) {
      cpf::parse_result<cpf::cst_node> result;
      auto forest = cpf::detail::earley_parse(tokens, grammar_spec, root_rule, options.allow_partial);
      if (!forest.success) {
         result.error = std::move(forest.error);
         return result;
      }
      result.partial = forest.partial;
      if (result.partial) {
         result.error = forest.error;
      }
      auto valid_tree_count = std::size_t{0};
      for (std::size_t tree_index = 0; tree_index < forest.forest.size(); ++tree_index) {
         const auto& tree = forest.forest[tree_index];
         if (!validate_generated_tree(tree)) {
            continue;
         }
         ++valid_tree_count;
         if (options.error_on_ambiguity && valid_tree_count > 1) {
            result.status = cpf::parse_status::failure;
            result.success = false;
            result.forest.clear();
            result.error = cpf::detail::make_ambiguity_error(grammar_rule_names[root_rule]);
            return result;
         }
         result.status = result.partial ? cpf::parse_status::partial_success : cpf::parse_status::success;
         result.success = true;
         if (options.build_ast) {
            result.forest.emplace_back(tree, definition_of_generated_tree(tree), tree->range, [tree]() { return build_cst_node(tree); }, forest.tree_damage[tree_index], forest.tree_partial[tree_index], [](const cpf::cst_node& root, std::vector<const cpf::node*>& damaged_nodes) {
               cpf::visit_cst_recursive(root, [&](const cpf::cst_node& current) {
                  if (current.is_damaged()) {
                     damaged_nodes.push_back(&current);
                  }
               });
            }, [tree](std::string_view repaired_input) { return cpf::detail::repaired_input_of(tree, repaired_input, grammar_spec); });
         }
      }
      if (result.success) {
         return result;
      }
      auto filtered_error = cpf::parse_error{};
      filtered_error.expected.push_back("valid parse tree");
      filtered_error.found.kind = cpf::parse_error_found_kind::filtered_parse;
      filtered_error.notes.push_back(std::string{R"(completed Earley parses for rule ')"} + std::string{grammar_rule_names[root_rule]} + R"(' were rejected by precedence/associativity constraints)");
      cpf::detail::error_tracker::finalize(filtered_error);
      result.error = std::move(filtered_error);
      return result;
   }

   [[maybe_unused]] cpf::parse_result<cpf::cst_node> parse_generated_cst(std::string_view input, std::size_t root_rule, const cpf::parse_options& options) {
      auto tokens = cpf::detail::lex_input(input, grammar_spec);
      return parse_generated_cst(tokens, root_rule, options);
   }
} // namespace

auto detail::lex_namespaced_calculator_generated(std::string_view input) -> cpf::token_sequence {
   return cpf::detail::lex_input(input, grammar_spec);
}

auto detail::parse_expression_default(std::string_view input, const cpf::parse_options& options) -> cpf::parse_result<expression> {
   auto tokens = detail::lex_namespaced_calculator_generated(input);
   return parse_expression_default(tokens, options);
}

auto detail::parse_expression_cst(std::string_view input, const cpf::parse_options& options) -> cpf::parse_result<cpf::cst_node> {
   auto tokens = detail::lex_namespaced_calculator_generated(input);
   return parse_expression_cst(tokens, options);
}

auto detail::parse_expression_default(const cpf::token_sequence& tokens, const cpf::parse_options& options) -> cpf::parse_result<expression> {
   auto result = cpf::parse_result<expression>{ };
   cpf::parse_error best_error;
   auto have_error = false;
   auto successful_children = std::size_t{0};
   auto have_partial_success = false;
   {
      auto child_result = detail::parse_addition_default(tokens, options);
      if (child_result.success) {
         if (!child_result.partial) {
            if (have_partial_success) {
               have_partial_success = false;
               successful_children = 0;
               result.status = cpf::parse_status::failure;
               result.partial = false;
               result.forest.clear();
            }
            result.status = cpf::parse_status::success;
            result.success = true;
            result.error.reset();
            successful_children += child_result.forest.size();
            if (options.error_on_ambiguity && successful_children > 1) {
               result.status = cpf::parse_status::failure;
               result.success = false;
               result.partial = false;
               result.forest.clear();
               result.error = cpf::detail::make_ambiguity_error("expression");
               return result;
            }
            if (options.build_ast) {
               for (const auto& tree : child_result.forest) {
                  auto opaque = std::static_pointer_cast<const cpf::detail::parse_node>(cpf::detail::opaque_tree_of(tree));
                  result.forest.emplace_back(opaque, tree.production_index(), tree.range(), [opaque]() {
                     auto built = build_node(opaque);
                     return release_built_node_as<expression>(std::move(built));
                  }, cpf::detail::pending_damage_of(tree), tree.is_partial(), [](const expression& root, std::vector<const cpf::node*>& damaged_nodes) {
                     visit_recursive(root, [&](auto& current) {
                        if (current.is_damaged()) {
                           damaged_nodes.push_back(&current);
                        }
                     });
                  }, [opaque](std::string_view repaired_input) { return cpf::detail::repaired_input_of(opaque, repaired_input, grammar_spec); });
               }
            }
         } else if (!result.success && !have_partial_success) {
            result.status = cpf::parse_status::partial_success;
            result.success = true;
            result.partial = true;
            result.error = child_result.error;
            have_partial_success = true;
            successful_children = child_result.forest.size();
            if (options.build_ast) {
               for (const auto& tree : child_result.forest) {
                  auto opaque = std::static_pointer_cast<const cpf::detail::parse_node>(cpf::detail::opaque_tree_of(tree));
                  result.forest.emplace_back(opaque, tree.production_index(), tree.range(), [opaque]() {
                     auto built = build_node(opaque);
                     return release_built_node_as<expression>(std::move(built));
                  }, cpf::detail::pending_damage_of(tree), tree.is_partial(), [](const expression& root, std::vector<const cpf::node*>& damaged_nodes) {
                     visit_recursive(root, [&](auto& current) {
                        if (current.is_damaged()) {
                           damaged_nodes.push_back(&current);
                        }
                     });
                  }, [opaque](std::string_view repaired_input) { return cpf::detail::repaired_input_of(opaque, repaired_input, grammar_spec); });
               }
            }
         }
      } else if (!have_error) {
         best_error = *child_result.error;
         have_error = true;
      } else {
         cpf::detail::merge_parse_error(best_error, *child_result.error);
      }
   }
   {
      auto child_result = detail::parse_number_default(tokens, options);
      if (child_result.success) {
         if (!child_result.partial) {
            if (have_partial_success) {
               have_partial_success = false;
               successful_children = 0;
               result.status = cpf::parse_status::failure;
               result.partial = false;
               result.forest.clear();
            }
            result.status = cpf::parse_status::success;
            result.success = true;
            result.error.reset();
            successful_children += child_result.forest.size();
            if (options.error_on_ambiguity && successful_children > 1) {
               result.status = cpf::parse_status::failure;
               result.success = false;
               result.partial = false;
               result.forest.clear();
               result.error = cpf::detail::make_ambiguity_error("expression");
               return result;
            }
            if (options.build_ast) {
               for (const auto& tree : child_result.forest) {
                  auto opaque = std::static_pointer_cast<const cpf::detail::parse_node>(cpf::detail::opaque_tree_of(tree));
                  result.forest.emplace_back(opaque, tree.production_index(), tree.range(), [opaque]() {
                     auto built = build_node(opaque);
                     return release_built_node_as<expression>(std::move(built));
                  }, cpf::detail::pending_damage_of(tree), tree.is_partial(), [](const expression& root, std::vector<const cpf::node*>& damaged_nodes) {
                     visit_recursive(root, [&](auto& current) {
                        if (current.is_damaged()) {
                           damaged_nodes.push_back(&current);
                        }
                     });
                  }, [opaque](std::string_view repaired_input) { return cpf::detail::repaired_input_of(opaque, repaired_input, grammar_spec); });
               }
            }
         } else if (!result.success && !have_partial_success) {
            result.status = cpf::parse_status::partial_success;
            result.success = true;
            result.partial = true;
            result.error = child_result.error;
            have_partial_success = true;
            successful_children = child_result.forest.size();
            if (options.build_ast) {
               for (const auto& tree : child_result.forest) {
                  auto opaque = std::static_pointer_cast<const cpf::detail::parse_node>(cpf::detail::opaque_tree_of(tree));
                  result.forest.emplace_back(opaque, tree.production_index(), tree.range(), [opaque]() {
                     auto built = build_node(opaque);
                     return release_built_node_as<expression>(std::move(built));
                  }, cpf::detail::pending_damage_of(tree), tree.is_partial(), [](const expression& root, std::vector<const cpf::node*>& damaged_nodes) {
                     visit_recursive(root, [&](auto& current) {
                        if (current.is_damaged()) {
