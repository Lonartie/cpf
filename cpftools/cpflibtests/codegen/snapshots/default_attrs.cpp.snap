auto detail::parse_default_expr_cst(const cpf::token_sequence& tokens, const cpf::parse_options& options) -> cpf::parse_result<cpf::cst_node> {
   return parse_generated_cst(tokens, 0, options);
}

auto detail::recognize_default_expr_default(std::string_view input) -> cpf::recognize_result {
   auto tokens = detail::lex_default_attrs_generated(input);
   return recognize_default_expr_default(tokens);
}

auto detail::recognize_default_expr_default(const cpf::token_sequence& tokens) -> cpf::recognize_result {
   cpf::recognize_result result;
   cpf::parse_error best_error;
   auto have_error = false;
   {
      auto child_result = detail::recognize_default_add_default(tokens);
      if (child_result.success) {
         result.success = true;
         result.error.reset();
         return result;
      }
      if (child_result.error.has_value()) {
         if (!have_error) {
            best_error = *child_result.error;
            have_error = true;
         } else {
            cpf::detail::merge_parse_error(best_error, *child_result.error);
         }
      }
   }
   {
      auto child_result = detail::recognize_default_subtract_default(tokens);
      if (child_result.success) {
         result.success = true;
         result.error.reset();
         return result;
      }
      if (child_result.error.has_value()) {
         if (!have_error) {
            best_error = *child_result.error;
            have_error = true;
         } else {
            cpf::detail::merge_parse_error(best_error, *child_result.error);
         }
      }
   }
   {
      auto child_result = detail::recognize_default_multiply_default(tokens);
      if (child_result.success) {
         result.success = true;
         result.error.reset();
         return result;
      }
      if (child_result.error.has_value()) {
         if (!have_error) {
            best_error = *child_result.error;
            have_error = true;
         } else {
            cpf::detail::merge_parse_error(best_error, *child_result.error);
         }
      }
   }
   {
      auto child_result = detail::recognize_default_number_default(tokens);
      if (child_result.success) {
         result.success = true;
         result.error.reset();
         return result;
      }
      if (child_result.error.has_value()) {
         if (!have_error) {
            best_error = *child_result.error;
            have_error = true;
         } else {
            cpf::detail::merge_parse_error(best_error, *child_result.error);
         }
      }
   }
   if (have_error) {
      cpf::detail::append_unique(best_error.notes, "while matching base rule 'default_expr'");
      cpf::detail::error_tracker::finalize(best_error);
      result.error = best_error;
   }
   return result;
}

namespace {
   std::array<cpf::complexity, 4> default_expr_complexity_cache{};
} // namespace

auto detail::complexity_inputs_default_expr_default(std::size_t production_index) -> std::span<const std::string_view> {
   switch (production_index) {
      case 0:
         return std::span<const std::string_view>{default_expr_complexity_inputs_0.data(), default_expr_complexity_inputs_0.size()};
      case 1:
         return std::span<const std::string_view>{default_expr_complexity_inputs_1.data(), default_expr_complexity_inputs_1.size()};
      case 2:
         return std::span<const std::string_view>{default_expr_complexity_inputs_2.data(), default_expr_complexity_inputs_2.size()};
      case 3:
         return std::span<const std::string_view>{default_expr_complexity_inputs_3.data(), default_expr_complexity_inputs_3.size()};
      default:
         throw std::out_of_range{"Unknown production index " + std::to_string(production_index) + " for rule 'default_expr'"};
   }
}

auto detail::complexity_default_expr_default(std::size_t production_index) -> const cpf::complexity& {
   switch (production_index) {
      case 0:
         return default_expr_complexity_cache[0];
      case 1:
         return default_expr_complexity_cache[1];
      case 2:
         return default_expr_complexity_cache[2];
      case 3:
         return default_expr_complexity_cache[3];
      default:
         throw std::out_of_range{"Unknown production index " + std::to_string(production_index) + " for rule 'default_expr'"};
   }
}

auto detail::recompute_complexity_default_expr_default(std::size_t production_index) -> const cpf::complexity& {
   switch (production_index) {
      case 0:
         default_expr_complexity_cache[0] = compute_generated_rule_complexity<default_expr>(default_expr_complexity_inputs_0, "default_expr", 0, 0);
         return default_expr_complexity_cache[0];
      case 1:
         default_expr_complexity_cache[1] = compute_generated_rule_complexity<default_expr>(default_expr_complexity_inputs_1, "default_expr", 1, 0);
         return default_expr_complexity_cache[1];
      case 2:
         default_expr_complexity_cache[2] = compute_generated_rule_complexity<default_expr>(default_expr_complexity_inputs_2, "default_expr", 2, 0);
         return default_expr_complexity_cache[2];
      case 3:
         default_expr_complexity_cache[3] = compute_generated_rule_complexity<default_expr>(default_expr_complexity_inputs_3, "default_expr", 3, 0);
         return default_expr_complexity_cache[3];
      default:
         throw std::out_of_range{"Unknown production index " + std::to_string(production_index) + " for rule 'default_expr'"};
   }
}

