/// @file
/// @brief Generated parser API for grammar 'calculator'.
/// @details
/// @li Public rules: 6.
/// @li Synthetic helper rules introduced during lowering: 0.
/// @li Recursive public rules detected from the grammar graph: expression, addition, subtraction, multiplication, division.
/// @li Rules with repeated-member storage: none.
/// @li Every generated parse entry point uses the shared Earley runtime with worst-case O(n^3) time and O(n^2) chart space for input length n.
/// @li Highly ambiguous grammars can grow the returned parse forest beyond the core Earley chart.
#pragma once

#include <array>
#include <cpflib>
#include <iomanip>
#include <iosfwd>
#include <memory>
#include <optional>
#include <sstream>
#include <span>
#include <stdexcept>
#include <string>
#include <string_view>
#include <typeinfo>
#include <type_traits>
#include <utility>
#include <variant>
#include <vector>

template<typename UserData = void> struct expression_node;
using expression = expression_node<>;
template<typename UserData = void> struct addition_node;
using addition = addition_node<>;
template<typename UserData = void> struct subtraction_node;
using subtraction = subtraction_node<>;
template<typename UserData = void> struct multiplication_node;
using multiplication = multiplication_node<>;
template<typename UserData = void> struct division_node;
using division = division_node<>;
template<typename UserData = void> struct number_node;
using number = number_node<>;

namespace detail {

template<typename Node, typename Parent, typename Visitor>
void invoke_calculator_recursive_visitor(Node& node, Parent* parent, Visitor&& visitor) {
   if constexpr (std::is_invocable_v<Visitor&&, Node&, Parent*>) {
      std::forward<Visitor>(visitor)(node, parent);
   } else {
      std::forward<Visitor>(visitor)(node);
   }
}

inline void write_calculator_debug_indent(std::ostream& os, std::size_t indent) {
   for (std::size_t i = 0; i < indent; ++i) {
      os << "  ";
   }
}

inline void write_calculator_debug_block(std::ostream& os, std::string_view block, std::size_t indent) {
   auto position = std::size_t{0};
   while (position <= block.size()) {
      auto line_end = block.find('\n', position);
      if (line_end == std::string_view::npos) {
         line_end = block.size();
      }
      write_calculator_debug_indent(os, indent);
      os << block.substr(position, line_end - position);
      if (line_end == block.size()) {
         break;
      }
      os << '\n';
      position = line_end + 1;
   }
}

} // namespace detail

