template<typename UserData>
auto expression_node<UserData>::lex(std::string_view input) -> cpf::token_sequence {
   return detail::lex_calculator_generated(input);
}

template<typename UserData>
auto expression_node<UserData>::parse_cst(std::string_view input, const cpf::parse_options& options) -> cst_parse_result {
   return detail::parse_expression_cst(input, options);
}

template<typename UserData>
auto expression_node<UserData>::parse_cst(const cpf::token_sequence& tokens, const cpf::parse_options& options) -> cst_parse_result {
   return detail::parse_expression_cst(tokens, options);
}

template<typename UserData>
auto expression_node<UserData>::parse(std::string_view input, const cpf::parse_options& options) -> parse_result {
   if constexpr (std::is_void_v<UserData>) {
      return detail::parse_expression_default(input, options);
   } else {
      auto default_result = detail::parse_expression_default(input, options);
      parse_result converted;
      converted.status = default_result.status;
      converted.success = default_result.success;
      converted.partial = default_result.partial;
      converted.error = std::move(default_result.error);
      if (!options.build_ast) {
         return converted;
      }
      converted.forest.reserve(default_result.forest.size());
      for (const auto& tree : default_result.forest) {
         auto materialized = tree.get();
         converted.forest.emplace_back(materialized != nullptr ? detail::rebind_expression_node<UserData>(*materialized) : nullptr);
      }
      return converted;
   }
}

template<typename UserData>
auto expression_node<UserData>::parse(const cpf::token_sequence& tokens, const cpf::parse_options& options) -> parse_result {
   if constexpr (std::is_void_v<UserData>) {
      return detail::parse_expression_default(tokens, options);
   } else {
      auto default_result = detail::parse_expression_default(tokens, options);
      parse_result converted;
      converted.status = default_result.status;
      converted.success = default_result.success;
      converted.partial = default_result.partial;
      converted.error = std::move(default_result.error);
      if (!options.build_ast) {
         return converted;
      }
      converted.forest.reserve(default_result.forest.size());
      for (const auto& tree : default_result.forest) {
         auto materialized = tree.get();
         converted.forest.emplace_back(materialized != nullptr ? detail::rebind_expression_node<UserData>(*materialized) : nullptr);
      }
      return converted;
   }
}

