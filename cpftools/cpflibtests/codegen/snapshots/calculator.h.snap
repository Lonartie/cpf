template<typename TargetUserData, typename SourceUserData>
auto rebind_expression_node(const expression_node<SourceUserData>& node) -> std::unique_ptr<expression_node<TargetUserData>>;

template<typename TargetUserData, typename SourceUserData>
auto rebind_addition_node(const addition_node<SourceUserData>& node) -> std::unique_ptr<addition_node<TargetUserData>>;

template<typename TargetUserData, typename SourceUserData>
auto rebind_subtraction_node(const subtraction_node<SourceUserData>& node) -> std::unique_ptr<subtraction_node<TargetUserData>>;

template<typename TargetUserData, typename SourceUserData>
auto rebind_multiplication_node(const multiplication_node<SourceUserData>& node) -> std::unique_ptr<multiplication_node<TargetUserData>>;

template<typename TargetUserData, typename SourceUserData>
auto rebind_division_node(const division_node<SourceUserData>& node) -> std::unique_ptr<division_node<TargetUserData>>;

template<typename TargetUserData, typename SourceUserData>
auto rebind_number_node(const number_node<SourceUserData>& node) -> std::unique_ptr<number_node<TargetUserData>>;

template<typename TargetUserData, typename SourceUserData>
auto rebind_expression_node(const expression_node<SourceUserData>& node) -> std::unique_ptr<expression_node<TargetUserData>> {
   switch (node.rule_id()) {
      case addition_node<SourceUserData>::RuleId:
         return rebind_addition_node<TargetUserData>(static_cast<const addition_node<SourceUserData>&>(node));
      case subtraction_node<SourceUserData>::RuleId:
         return rebind_subtraction_node<TargetUserData>(static_cast<const subtraction_node<SourceUserData>&>(node));
      case multiplication_node<SourceUserData>::RuleId:
         return rebind_multiplication_node<TargetUserData>(static_cast<const multiplication_node<SourceUserData>&>(node));
      case division_node<SourceUserData>::RuleId:
         return rebind_division_node<TargetUserData>(static_cast<const division_node<SourceUserData>&>(node));
      case number_node<SourceUserData>::RuleId:
         return rebind_number_node<TargetUserData>(static_cast<const number_node<SourceUserData>&>(node));
      default:
         throw std::bad_cast{};
   }
}

template<typename TargetUserData, typename SourceUserData>
auto rebind_addition_node(const addition_node<SourceUserData>& node) -> std::unique_ptr<addition_node<TargetUserData>> {
   auto copy = std::make_unique<addition_node<TargetUserData>>();
   copy->production_index = node.production_index;
   copy->range = node.range;
   for (const auto& damage : node.damage()) {
      cpf::detail::add_damage(*copy, damage);
   }
   if constexpr (!std::is_void_v<TargetUserData> && !std::is_void_v<SourceUserData>) {
      copy->user_data = node.user_data;
   }
   copy->left = node.left ? detail::rebind_expression_node<TargetUserData>(*node.left) : nullptr;
   copy->op = node.op;
   copy->right = node.right ? detail::rebind_expression_node<TargetUserData>(*node.right) : nullptr;
   return copy;
}

template<typename TargetUserData, typename SourceUserData>
auto rebind_subtraction_node(const subtraction_node<SourceUserData>& node) -> std::unique_ptr<subtraction_node<TargetUserData>> {
   auto copy = std::make_unique<subtraction_node<TargetUserData>>();
   copy->production_index = node.production_index;
   copy->range = node.range;
   for (const auto& damage : node.damage()) {
      cpf::detail::add_damage(*copy, damage);
   }
   if constexpr (!std::is_void_v<TargetUserData> && !std::is_void_v<SourceUserData>) {
      copy->user_data = node.user_data;
   }
   copy->left = node.left ? detail::rebind_expression_node<TargetUserData>(*node.left) : nullptr;
   copy->op = node.op;
   copy->right = node.right ? detail::rebind_expression_node<TargetUserData>(*node.right) : nullptr;
   return copy;
}

template<typename TargetUserData, typename SourceUserData>
auto rebind_multiplication_node(const multiplication_node<SourceUserData>& node) -> std::unique_ptr<multiplication_node<TargetUserData>> {
   auto copy = std::make_unique<multiplication_node<TargetUserData>>();
   copy->production_index = node.production_index;
   copy->range = node.range;
   for (const auto& damage : node.damage()) {
      cpf::detail::add_damage(*copy, damage);
   }
   if constexpr (!std::is_void_v<TargetUserData> && !std::is_void_v<SourceUserData>) {
      copy->user_data = node.user_data;
   }
   copy->left = node.left ? detail::rebind_expression_node<TargetUserData>(*node.left) : nullptr;
   copy->op = node.op;
   copy->right = node.right ? detail::rebind_expression_node<TargetUserData>(*node.right) : nullptr;
   return copy;
}

template<typename TargetUserData, typename SourceUserData>
auto rebind_division_node(const division_node<SourceUserData>& node) -> std::unique_ptr<division_node<TargetUserData>> {
   auto copy = std::make_unique<division_node<TargetUserData>>();
   copy->production_index = node.production_index;
   copy->range = node.range;
   for (const auto& damage : node.damage()) {
      cpf::detail::add_damage(*copy, damage);
   }
   if constexpr (!std::is_void_v<TargetUserData> && !std::is_void_v<SourceUserData>) {
      copy->user_data = node.user_data;
   }
   copy->left = node.left ? detail::rebind_expression_node<TargetUserData>(*node.left) : nullptr;
   copy->op = node.op;
   copy->right = node.right ? detail::rebind_expression_node<TargetUserData>(*node.right) : nullptr;
   return copy;
}

template<typename TargetUserData, typename SourceUserData>
auto rebind_number_node(const number_node<SourceUserData>& node) -> std::unique_ptr<number_node<TargetUserData>> {
   auto copy = std::make_unique<number_node<TargetUserData>>();
   copy->production_index = node.production_index;
   copy->range = node.range;
   for (const auto& damage : node.damage()) {
      cpf::detail::add_damage(*copy, damage);
   }
   if constexpr (!std::is_void_v<TargetUserData> && !std::is_void_v<SourceUserData>) {
      copy->user_data = node.user_data;
   }
   copy->value = node.value;
   return copy;
}

