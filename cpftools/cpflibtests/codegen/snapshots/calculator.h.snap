template<typename UserData>
std::ostream& operator<<(std::ostream& os, const addition_node<UserData>& node) {
   os << "addition(\n";
   detail::write_calculator_debug_indent(os, 1);
   os << "left =";
   if (node.left) {
      os << '\n';
      auto nested_stream = std::ostringstream{};
      nested_stream << *node.left;
      detail::write_calculator_debug_block(os, nested_stream.str(), 2);
   } else {
      os << " null";
   }
   os << ',';
   os << '\n';
   detail::write_calculator_debug_indent(os, 1);
   os << "op =";
   os << " " << std::quoted(node.op.text);
   os << ',';
   os << '\n';
   detail::write_calculator_debug_indent(os, 1);
   os << "right =";
   if (node.right) {
      os << '\n';
      auto nested_stream = std::ostringstream{};
      nested_stream << *node.right;
      detail::write_calculator_debug_block(os, nested_stream.str(), 2);
   } else {
      os << " null";
   }
   os << '\n';
   os << ')';
   return os;
}

