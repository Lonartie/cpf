template<typename UserData>
std::ostream& operator<<(std::ostream& os, const expression_node<UserData>& node) {
   switch (node.rule_id()) {
      case addition_node<UserData>::RuleId:
         return os << static_cast<const addition_node<UserData>&>(node);
      case subtraction_node<UserData>::RuleId:
         return os << static_cast<const subtraction_node<UserData>&>(node);
      case multiplication_node<UserData>::RuleId:
         return os << static_cast<const multiplication_node<UserData>&>(node);
      case division_node<UserData>::RuleId:
         return os << static_cast<const division_node<UserData>&>(node);
      case number_node<UserData>::RuleId:
         return os << static_cast<const number_node<UserData>&>(node);
      default:
         return os << "expression()";
   }
}

