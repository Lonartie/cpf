template<typename UserData, typename Visitor>
auto visit(const expression_node<UserData>& node, Visitor&& visitor) {
   switch (node.rule_id()) {
      case addition_node<UserData>::RuleId:
         return visit(static_cast<const addition_node<UserData>&>(node), visitor);
      case subtraction_node<UserData>::RuleId:
         return visit(static_cast<const subtraction_node<UserData>&>(node), visitor);
      case multiplication_node<UserData>::RuleId:
         return visit(static_cast<const multiplication_node<UserData>&>(node), visitor);
      case division_node<UserData>::RuleId:
         return visit(static_cast<const division_node<UserData>&>(node), visitor);
      case number_node<UserData>::RuleId:
         return visit(static_cast<const number_node<UserData>&>(node), visitor);
      default:
         throw std::bad_cast{};
   }
}

template<typename UserData, typename Visitor>
auto visit(expression_node<UserData>& node, Visitor&& visitor) {
   switch (node.rule_id()) {
      case addition_node<UserData>::RuleId:
         return visit(static_cast<addition_node<UserData>&>(node), visitor);
      case subtraction_node<UserData>::RuleId:
         return visit(static_cast<subtraction_node<UserData>&>(node), visitor);
      case multiplication_node<UserData>::RuleId:
         return visit(static_cast<multiplication_node<UserData>&>(node), visitor);
      case division_node<UserData>::RuleId:
         return visit(static_cast<division_node<UserData>&>(node), visitor);
      case number_node<UserData>::RuleId:
         return visit(static_cast<number_node<UserData>&>(node), visitor);
      default:
         throw std::bad_cast{};
   }
}

template<typename UserData, typename Visitor>
void visit_recursive(const expression_node<UserData>& node, Visitor&& visitor) {
   visit_recursive(node, std::forward<Visitor>(visitor), static_cast<const cpf::node*>(nullptr));
}

template<typename UserData, typename Visitor, typename Parent>
void visit_recursive(const expression_node<UserData>& node, Visitor&& visitor, const Parent* parent) {
   switch (node.rule_id()) {
      case addition_node<UserData>::RuleId:
         visit_recursive(static_cast<const addition_node<UserData>&>(node), visitor, parent);
         return;
      case subtraction_node<UserData>::RuleId:
         visit_recursive(static_cast<const subtraction_node<UserData>&>(node), visitor, parent);
         return;
      case multiplication_node<UserData>::RuleId:
         visit_recursive(static_cast<const multiplication_node<UserData>&>(node), visitor, parent);
         return;
      case division_node<UserData>::RuleId:
         visit_recursive(static_cast<const division_node<UserData>&>(node), visitor, parent);
         return;
      case number_node<UserData>::RuleId:
         visit_recursive(static_cast<const number_node<UserData>&>(node), visitor, parent);
         return;
      default:
         throw std::bad_cast{};
   }
}

template<typename UserData, typename Visitor>
void visit_recursive(expression_node<UserData>& node, Visitor&& visitor) {
   visit_recursive(node, std::forward<Visitor>(visitor), static_cast<cpf::node*>(nullptr));
}

template<typename UserData, typename Visitor, typename Parent>
void visit_recursive(expression_node<UserData>& node, Visitor&& visitor, Parent* parent) {
   switch (node.rule_id()) {
      case addition_node<UserData>::RuleId:
         visit_recursive(static_cast<addition_node<UserData>&>(node), visitor, parent);
         return;
      case subtraction_node<UserData>::RuleId:
         visit_recursive(static_cast<subtraction_node<UserData>&>(node), visitor, parent);
         return;
      case multiplication_node<UserData>::RuleId:
         visit_recursive(static_cast<multiplication_node<UserData>&>(node), visitor, parent);
         return;
      case division_node<UserData>::RuleId:
         visit_recursive(static_cast<division_node<UserData>&>(node), visitor, parent);
         return;
      case number_node<UserData>::RuleId:
         visit_recursive(static_cast<number_node<UserData>&>(node), visitor, parent);
         return;
      default:
         throw std::bad_cast{};
   }
}

template<typename UserData, typename Visitor>
auto visit(const addition_node<UserData>& node, Visitor&& visitor) {
   return std::forward<Visitor>(visitor)(node);
}

template<typename UserData, typename Visitor>
auto visit(addition_node<UserData>& node, Visitor&& visitor) {
   return std::forward<Visitor>(visitor)(node);
}

template<typename UserData, typename Visitor>
void visit_recursive(const addition_node<UserData>& node, Visitor&& visitor) {
   visit_recursive(node, std::forward<Visitor>(visitor), static_cast<const cpf::node*>(nullptr));
}

template<typename UserData, typename Visitor, typename Parent>
void visit_recursive(const addition_node<UserData>& node, Visitor&& visitor, const Parent* parent) {
   detail::invoke_calculator_recursive_visitor(node, parent, std::forward<Visitor>(visitor));
   if (node.left) {
      visit_recursive(*node.left, visitor, &node);
   }
   if (node.right) {
      visit_recursive(*node.right, visitor, &node);
   }
}

template<typename UserData, typename Visitor>
void visit_recursive(addition_node<UserData>& node, Visitor&& visitor) {
