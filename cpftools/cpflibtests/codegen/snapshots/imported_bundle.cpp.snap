auto detail::recompute_complexity_imported_bundle_greeting_default(std::size_t production_index) -> const cpf::complexity& {
   switch (production_index) {
      case 0:
         imported_bundle_greeting_complexity_cache[0] = compute_generated_rule_complexity<imported_bundle_greeting>(imported_bundle_greeting_complexity_inputs_0, "imported_bundle_greeting", 0, 2);
