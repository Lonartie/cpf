   template<typename Rule, std::size_t SampleCount>
   cpf::complexity compute_generated_rule_complexity(const std::array<std::string_view, SampleCount>& inputs, std::string_view rule_name, std::size_t rule_id, std::size_t root_rule) {
      std::vector<std::tuple<std::string_view>> args;
      args.reserve(inputs.size());
      std::vector<double> arg_sizes;
      arg_sizes.reserve(inputs.size());
      for (const auto input : inputs) {
         args.emplace_back(input);
         arg_sizes.push_back(static_cast<double>(input.size()));
      }
      return cpf::complexity_of(
         [rule_name, rule_id, root_rule](std::string_view input) {
            auto result = cpf::detail::earley_recognize(input, grammar_spec, root_rule);
            if (!result.success) {
               throw std::runtime_error{"Generated complexity sample for rule '" + std::string{rule_name} + "' definition " + std::to_string(rule_id) + " failed to parse input: " + (result.error.has_value() ? result.error->message : std::string{"unknown parse failure"})};
            }
            return static_cast<std::size_t>(result.success);
         },
         std::move(args),
         std::move(arg_sizes));
   }
   std::unique_ptr<cpf::node> build_node(const parse_node_ptr& tree);

   template<typename T>
   std::unique_ptr<T> release_built_node_as(std::unique_ptr<cpf::node> built) {
      if (built == nullptr) {
         return nullptr;
      }
      auto* raw = dynamic_cast<T*>(built.get());
      if (raw == nullptr) {
         throw std::runtime_error{"Generated node cast failed"};
      }
      built.release();
      return std::unique_ptr<T>{raw};
   }

   parse_node_ptr node_child_at(const parse_node_ptr& tree, std::size_t index) {
      if (index >= tree->children.size()) {
         throw std::runtime_error{"Generated parse tree missing node child"};
      }
      const auto* child = std::get_if<parse_node_ptr>(&tree->children[index]);
      if (child == nullptr || *child == nullptr) {
         throw std::runtime_error{"Generated parse tree child is not a node"};
      }
      return *child;
   }

   cpf::matched_string matched_child_at(const parse_node_ptr& tree, std::size_t index) {
      if (index >= tree->children.size()) {
         throw std::runtime_error{"Generated parse tree missing terminal child"};
      }
      const auto* child = std::get_if<cpf::matched_string>(&tree->children[index]);
      if (child == nullptr) {
         throw std::runtime_error{"Generated parse tree child is not a terminal"};
      }
      return *child;
   }

   [[maybe_unused]] void append_matched_tree_text(const parse_node_ptr& tree, std::string& text) {
      for (const auto& child : tree->children) {
         if (const auto* matched = std::get_if<cpf::matched_string>(&child); matched != nullptr) {
            text += matched->text;
            continue;
         }
         const auto* node = std::get_if<parse_node_ptr>(&child);
         if (node == nullptr || *node == nullptr) {
            throw std::runtime_error{"Generated parse tree child is not materializable as token text"};
         }
         append_matched_tree_text(*node, text);
      }
   }

   [[maybe_unused]] cpf::matched_string matched_tree_at(const parse_node_ptr& tree) {
      cpf::matched_string matched;
      matched.range = tree->range;
      append_matched_tree_text(tree, matched.text);
      return matched;
   }


   std::size_t definition_of_generated_tree(const parse_node_ptr& tree) {
      switch (tree->production) {
         case 0:
            return 0;
         case 1:
            return 1;
         case 2:
            return 0;
         case 3:
            return 0;
         case 4:
            return 0;
         case 5:
            return 0;
         case 6:
            return 1;
         default:
            return 0;
      }
   }

   [[maybe_unused]] bool validate_generated_node(const cpf::node& node) {
      switch (node.rule_id()) {
         case imported_bundle_word::RuleId: {
            return true;
         }
         case imported_bundle_suffix::RuleId: {
            return true;
         }
         case imported_bundle_greeting::RuleId: {
            const auto& value = static_cast<const imported_bundle_greeting&>(node);
            if (value.text && !validate_generated_node(*value.text)) {
               return false;
            }
            if (value.suffix && !validate_generated_node(*value.suffix)) {
               return false;
            }
            return true;
         }
         case imported_bundle_parting::RuleId: {
            return true;
         }
         default:
            return true;
      }
   }

   bool validate_generated_tree(const parse_node_ptr& tree) {
      for (const auto& child : tree->children) {
         if (std::holds_alternative<parse_node_ptr>(child) && !validate_generated_tree(std::get<parse_node_ptr>(child))) {
            return false;
         }
      }
      switch (tree->production) {
         case 0: {
            return true;
         }
         case 1: {
            return true;
         }
         case 2: {
            return true;
         }
         case 3: {
            return true;
         }
         case 4: {
            return true;
         }
         case 5: {
            return true;
         }
         case 6: {
            return true;
         }
         default:
            return true;
      }
   }

   std::unique_ptr<cpf::node> build_node(const parse_node_ptr& tree) {
      switch (tree->production) {
         case 0: {
            auto node = std::make_unique<imported_bundle_word>();
            node->production_index = 0;
            node->range = tree->range;
            for (const auto& damage : tree->damage) {
               cpf::detail::add_damage(*node, damage);
            }
            node->value = matched_child_at(tree, 0);
            return node;
         }
         case 1: {
            auto node = std::make_unique<imported_bundle_word>();
            node->production_index = 1;
            node->range = tree->range;
            for (const auto& damage : tree->damage) {
               cpf::detail::add_damage(*node, damage);
            }
            node->value = matched_child_at(tree, 0);
            return node;
         }
         case 2: {
            auto node = std::make_unique<imported_bundle_suffix>();
            node->production_index = 0;
            node->range = tree->range;
            for (const auto& damage : tree->damage) {
               cpf::detail::add_damage(*node, damage);
            }
            node->value = matched_child_at(tree, 0);
            return node;
         }
         case 3: {
            auto node = std::make_unique<imported_bundle_greeting>();
            node->production_index = 0;
            node->range = tree->range;
            for (const auto& damage : tree->damage) {
               cpf::detail::add_damage(*node, damage);
            }
            auto child_0 = build_node(node_child_at(tree, 0));
            node->text = release_built_node_as<imported_bundle_word>(std::move(child_0));
            auto child_1 = build_node(node_child_at(tree, 1));
            node->suffix = release_built_node_as<imported_bundle_suffix>(std::move(child_1));
            return node;
         }
         case 4: {
            auto node = std::make_unique<imported_bundle_parting>();
            node->production_index = 0;
            node->range = tree->range;
            for (const auto& damage : tree->damage) {
               cpf::detail::add_damage(*node, damage);
            }
            node->text = matched_child_at(tree, 0);
            return node;
         }
         case 5: {
            return build_node(node_child_at(tree, 0));
         }
         case 6: {
            return build_node(node_child_at(tree, 0));
         }
         default:
            throw std::runtime_error{"Unknown parse production"};
      }
   }

   template<typename T>
   cpf::recognize_result recognize_generated(const cpf::token_sequence& tokens, std::size_t root_rule) {
      cpf::recognize_result result;
      auto recognized = cpf::detail::earley_recognize(tokens, grammar_spec, root_rule);
      result.success = recognized.success;
      if (!recognized.success) {
         result.error = std::move(recognized.error);
      }
      return result;
   }

   template<typename T>
   cpf::recognize_result recognize_generated(std::string_view input, std::size_t root_rule) {
      auto tokens = cpf::detail::lex_input(input, grammar_spec);
      return recognize_generated<T>(tokens, root_rule);
   }

   template<typename T>
   cpf::parse_result<T> parse_generated(const cpf::token_sequence& tokens, std::size_t root_rule, const cpf::parse_options& options) {
      cpf::parse_result<T> result;
      auto forest = cpf::detail::earley_parse(tokens, grammar_spec, root_rule, options.allow_partial);
      if (!forest.success) {
         result.error = std::move(forest.error);
         return result;
      }
      result.partial = forest.partial;
      if (result.partial) {
         result.error = forest.error;
      }
      auto valid_tree_count = std::size_t{0};
      for (std::size_t tree_index = 0; tree_index < forest.forest.size(); ++tree_index) {
         const auto& tree = forest.forest[tree_index];
         if (!validate_generated_tree(tree)) {
            continue;
         }
         ++valid_tree_count;
         if (options.error_on_ambiguity && valid_tree_count > 1) {
            result.status = cpf::parse_status::failure;
            result.success = false;
            result.forest.clear();
            result.error = cpf::detail::make_ambiguity_error(grammar_rule_names[root_rule]);
            return result;
         }
         result.status = result.partial ? cpf::parse_status::partial_success : cpf::parse_status::success;
         result.success = true;
         if (options.build_ast) {
            result.forest.emplace_back(tree, definition_of_generated_tree(tree), tree->range, [tree]() {
               auto built = build_node(tree);
               return release_built_node_as<T>(std::move(built));
            }, forest.tree_damage[tree_index], forest.tree_partial[tree_index], [](const T& root, std::vector<const cpf::node*>& damaged_nodes) {
               visit_recursive(root, [&](auto& current) {
                  if (current.is_damaged()) {
                     damaged_nodes.push_back(&current);
                  }
               });
            }, [tree](std::string_view repaired_input) { return cpf::detail::repaired_input_of(tree, repaired_input, grammar_spec); });
         }
      }
      if (result.success) {
         return result;
      }
      auto filtered_error = cpf::parse_error{};
      filtered_error.expected.push_back("valid parse tree");
      filtered_error.found.kind = cpf::parse_error_found_kind::filtered_parse;
      filtered_error.notes.push_back(std::string{R"(completed Earley parses for rule ')"} + std::string{grammar_rule_names[root_rule]} + R"(' were rejected by precedence/associativity constraints)");
      cpf::detail::error_tracker::finalize(filtered_error);
      result.error = std::move(filtered_error);
      return result;
   }

   template<typename T>
   cpf::parse_result<T> parse_generated(std::string_view input, std::size_t root_rule, const cpf::parse_options& options) {
      auto tokens = cpf::detail::lex_input(input, grammar_spec);
      return parse_generated<T>(tokens, root_rule, options);
   }
} // namespace

auto detail::lex_imported_bundle_generated(std::string_view input) -> cpf::token_sequence {
   return cpf::detail::lex_input(input, grammar_spec);
}

auto detail::parse_imported_bundle_word_default(std::string_view input, const cpf::parse_options& options) -> cpf::parse_result<imported_bundle_word> {
   auto tokens = detail::lex_imported_bundle_generated(input);
   return parse_imported_bundle_word_default(tokens, options);
}

auto detail::parse_imported_bundle_word_default(const cpf::token_sequence& tokens, const cpf::parse_options& options) -> cpf::parse_result<imported_bundle_word> {
   return parse_generated<imported_bundle_word>(tokens, 0, options);
}

auto detail::recognize_imported_bundle_word_default(std::string_view input) -> cpf::recognize_result {
   auto tokens = detail::lex_imported_bundle_generated(input);
   return recognize_imported_bundle_word_default(tokens);
}

auto detail::recognize_imported_bundle_word_default(const cpf::token_sequence& tokens) -> cpf::recognize_result {
   return recognize_generated<imported_bundle_word>(tokens, 0);
}

namespace {
   std::array<cpf::complexity, 2> imported_bundle_word_complexity_cache{};
} // namespace

auto detail::complexity_inputs_imported_bundle_word_default(std::size_t production_index) -> std::span<const std::string_view> {
   switch (production_index) {
      case 0:
         return std::span<const std::string_view>{imported_bundle_word_complexity_inputs_0.data(), imported_bundle_word_complexity_inputs_0.size()};
      case 1:
         return std::span<const std::string_view>{imported_bundle_word_complexity_inputs_1.data(), imported_bundle_word_complexity_inputs_1.size()};
      default:
         throw std::out_of_range{"Unknown production index " + std::to_string(production_index) + " for rule 'imported_bundle_word'"};
   }
}

auto detail::complexity_imported_bundle_word_default(std::size_t production_index) -> const cpf::complexity& {
   switch (production_index) {
      case 0:
         return imported_bundle_word_complexity_cache[0];
      case 1:
         return imported_bundle_word_complexity_cache[1];
      default:
         throw std::out_of_range{"Unknown production index " + std::to_string(production_index) + " for rule 'imported_bundle_word'"};
   }
}

auto detail::recompute_complexity_imported_bundle_word_default(std::size_t production_index) -> const cpf::complexity& {
   switch (production_index) {
      case 0:
         imported_bundle_word_complexity_cache[0] = compute_generated_rule_complexity<imported_bundle_word>(imported_bundle_word_complexity_inputs_0, "imported_bundle_word", 0, 0);
         return imported_bundle_word_complexity_cache[0];
      case 1:
         imported_bundle_word_complexity_cache[1] = compute_generated_rule_complexity<imported_bundle_word>(imported_bundle_word_complexity_inputs_1, "imported_bundle_word", 1, 0);
         return imported_bundle_word_complexity_cache[1];
      default:
         throw std::out_of_range{"Unknown production index " + std::to_string(production_index) + " for rule 'imported_bundle_word'"};
   }
}

