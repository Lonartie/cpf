template<typename UserData>
std::ostream& operator<<(std::ostream& os, const imported_bundle_greeting_node<UserData>& node) {
   os << "imported_bundle_greeting(\n";
   detail::write_imported_bundle_debug_indent(os, 1);
   os << "text =";
   if (node.text) {
      os << '\n';
      auto nested_stream = std::ostringstream{};
      nested_stream << *node.text;
      detail::write_imported_bundle_debug_block(os, nested_stream.str(), 2);
   } else {
      os << " null";
   }
   os << ',';
   os << '\n';
   detail::write_imported_bundle_debug_indent(os, 1);
   os << "suffix =";
   if (node.suffix) {
      os << '\n';
      auto nested_stream = std::ostringstream{};
      nested_stream << *node.suffix;
      detail::write_imported_bundle_debug_block(os, nested_stream.str(), 2);
   } else {
      os << " null";
   }
   os << '\n';
   os << ')';
   return os;
}

