template<typename UserData>
std::ostream& operator<<(std::ostream& os, const imported_bundle_message_node<UserData>& node) {
   switch (node.rule_id()) {
      case imported_bundle_greeting_node<UserData>::RuleId:
         return os << static_cast<const imported_bundle_greeting_node<UserData>&>(node);
      case imported_bundle_parting_node<UserData>::RuleId:
         return os << static_cast<const imported_bundle_parting_node<UserData>&>(node);
      default:
         return os << "imported_bundle_message()";
   }
}

