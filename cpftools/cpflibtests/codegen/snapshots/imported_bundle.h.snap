template<typename TargetUserData, typename SourceUserData>
auto rebind_imported_bundle_word_node(const imported_bundle_word_node<SourceUserData>& node) -> std::unique_ptr<imported_bundle_word_node<TargetUserData>>;

template<typename TargetUserData, typename SourceUserData>
auto rebind_imported_bundle_suffix_node(const imported_bundle_suffix_node<SourceUserData>& node) -> std::unique_ptr<imported_bundle_suffix_node<TargetUserData>>;

template<typename TargetUserData, typename SourceUserData>
auto rebind_imported_bundle_greeting_node(const imported_bundle_greeting_node<SourceUserData>& node) -> std::unique_ptr<imported_bundle_greeting_node<TargetUserData>>;

template<typename TargetUserData, typename SourceUserData>
auto rebind_imported_bundle_parting_node(const imported_bundle_parting_node<SourceUserData>& node) -> std::unique_ptr<imported_bundle_parting_node<TargetUserData>>;

template<typename TargetUserData, typename SourceUserData>
auto rebind_imported_bundle_message_node(const imported_bundle_message_node<SourceUserData>& node) -> std::unique_ptr<imported_bundle_message_node<TargetUserData>>;

template<typename TargetUserData, typename SourceUserData>
auto rebind_imported_bundle_word_node(const imported_bundle_word_node<SourceUserData>& node) -> std::unique_ptr<imported_bundle_word_node<TargetUserData>> {
   auto copy = std::make_unique<imported_bundle_word_node<TargetUserData>>();
   copy->production_index = node.production_index;
   copy->range = node.range;
   for (const auto& damage : node.damage()) {
      cpf::detail::add_damage(*copy, damage);
   }
   if constexpr (!std::is_void_v<TargetUserData> && !std::is_void_v<SourceUserData>) {
      copy->user_data = node.user_data;
   }
   copy->value = node.value;
   return copy;
}

template<typename TargetUserData, typename SourceUserData>
auto rebind_imported_bundle_suffix_node(const imported_bundle_suffix_node<SourceUserData>& node) -> std::unique_ptr<imported_bundle_suffix_node<TargetUserData>> {
   auto copy = std::make_unique<imported_bundle_suffix_node<TargetUserData>>();
   copy->production_index = node.production_index;
   copy->range = node.range;
   for (const auto& damage : node.damage()) {
      cpf::detail::add_damage(*copy, damage);
   }
   if constexpr (!std::is_void_v<TargetUserData> && !std::is_void_v<SourceUserData>) {
      copy->user_data = node.user_data;
   }
   copy->value = node.value;
   return copy;
}

template<typename TargetUserData, typename SourceUserData>
auto rebind_imported_bundle_greeting_node(const imported_bundle_greeting_node<SourceUserData>& node) -> std::unique_ptr<imported_bundle_greeting_node<TargetUserData>> {
   auto copy = std::make_unique<imported_bundle_greeting_node<TargetUserData>>();
   copy->production_index = node.production_index;
   copy->range = node.range;
   for (const auto& damage : node.damage()) {
      cpf::detail::add_damage(*copy, damage);
   }
   if constexpr (!std::is_void_v<TargetUserData> && !std::is_void_v<SourceUserData>) {
      copy->user_data = node.user_data;
   }
   copy->text = node.text ? detail::rebind_imported_bundle_word_node<TargetUserData>(*node.text) : nullptr;
   copy->suffix = node.suffix ? detail::rebind_imported_bundle_suffix_node<TargetUserData>(*node.suffix) : nullptr;
   return copy;
}

template<typename TargetUserData, typename SourceUserData>
auto rebind_imported_bundle_parting_node(const imported_bundle_parting_node<SourceUserData>& node) -> std::unique_ptr<imported_bundle_parting_node<TargetUserData>> {
   auto copy = std::make_unique<imported_bundle_parting_node<TargetUserData>>();
   copy->production_index = node.production_index;
   copy->range = node.range;
   for (const auto& damage : node.damage()) {
      cpf::detail::add_damage(*copy, damage);
   }
   if constexpr (!std::is_void_v<TargetUserData> && !std::is_void_v<SourceUserData>) {
      copy->user_data = node.user_data;
   }
   copy->text = node.text;
   return copy;
}

template<typename TargetUserData, typename SourceUserData>
auto rebind_imported_bundle_message_node(const imported_bundle_message_node<SourceUserData>& node) -> std::unique_ptr<imported_bundle_message_node<TargetUserData>> {
   switch (node.rule_id()) {
      case imported_bundle_greeting_node<SourceUserData>::RuleId:
         return rebind_imported_bundle_greeting_node<TargetUserData>(static_cast<const imported_bundle_greeting_node<SourceUserData>&>(node));
      case imported_bundle_parting_node<SourceUserData>::RuleId:
         return rebind_imported_bundle_parting_node<TargetUserData>(static_cast<const imported_bundle_parting_node<SourceUserData>&>(node));
      default:
         throw std::bad_cast{};
   }
}

} // namespace detail

template<typename UserData>
auto imported_bundle_word_node<UserData>::lex(std::string_view input) -> cpf::token_sequence {
   return detail::lex_imported_bundle_generated(input);
}

template<typename UserData>
auto imported_bundle_word_node<UserData>::parse_cst(std::string_view input, const cpf::parse_options& options) -> cst_parse_result {
   return detail::parse_imported_bundle_word_cst(input, options);
}

template<typename UserData>
auto imported_bundle_word_node<UserData>::parse_cst(const cpf::token_sequence& tokens, const cpf::parse_options& options) -> cst_parse_result {
   return detail::parse_imported_bundle_word_cst(tokens, options);
}

template<typename UserData>
auto imported_bundle_word_node<UserData>::parse(std::string_view input, const cpf::parse_options& options) -> parse_result {
   if constexpr (std::is_void_v<UserData>) {
      return detail::parse_imported_bundle_word_default(input, options);
   } else {
      auto default_result = detail::parse_imported_bundle_word_default(input, options);
      parse_result converted;
      converted.status = default_result.status;
      converted.success = default_result.success;
      converted.partial = default_result.partial;
      converted.error = std::move(default_result.error);
      if (!options.build_ast) {
         return converted;
      }
      converted.forest.reserve(default_result.forest.size());
      for (const auto& tree : default_result.forest) {
         auto materialized = tree.get();
         converted.forest.emplace_back(materialized != nullptr ? detail::rebind_imported_bundle_word_node<UserData>(*materialized) : nullptr);
      }
      return converted;
   }
}

template<typename UserData>
auto imported_bundle_word_node<UserData>::parse(const cpf::token_sequence& tokens, const cpf::parse_options& options) -> parse_result {
   if constexpr (std::is_void_v<UserData>) {
      return detail::parse_imported_bundle_word_default(tokens, options);
   } else {
      auto default_result = detail::parse_imported_bundle_word_default(tokens, options);
      parse_result converted;
      converted.status = default_result.status;
      converted.success = default_result.success;
      converted.partial = default_result.partial;
      converted.error = std::move(default_result.error);
      if (!options.build_ast) {
         return converted;
      }
      converted.forest.reserve(default_result.forest.size());
      for (const auto& tree : default_result.forest) {
         auto materialized = tree.get();
         converted.forest.emplace_back(materialized != nullptr ? detail::rebind_imported_bundle_word_node<UserData>(*materialized) : nullptr);
      }
      return converted;
   }
}

