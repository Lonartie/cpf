                     escaped += "\\\\";
                     break;
                  case '\n':
                     escaped += "\\n";
                     break;
                  case '\r':
                     escaped += "\\r";
                     break;
                  case '\t':
                     escaped += "\\t";
                     break;
                  case '"':
                     escaped += "\\\"";
                     break;
                  default:
