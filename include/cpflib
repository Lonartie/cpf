            if (base_it == bases.end()) {
               break;
            }
            current = base_it->second;
         }

         current = std::string{right};
         while (!current.empty()) {
            if (left_ancestors.contains(current)) {
               return current;
            }
            auto base_it = bases.find(current);
            if (base_it == bases.end()) {
               break;
            }
            current = base_it->second;
         }

