            throw std::runtime_error{"Grammar parse error at line " +
                                     std::to_string(parsed_grammar.whitespace_rule_line) +
                                     ", column 1: @whitespace references unknown skip rule '" +
                                     *parsed_grammar.whitespace_rule + "'"};
         }

