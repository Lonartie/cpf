      [[nodiscard]] bool symbol_nullable(const symbol& symbol,
                                         const std::unordered_map<std::string, bool>& nullable_rules) {
         if (is_nullable_quantifier(symbol.quantifier, symbol.exact_repetition)) {
            return true;
