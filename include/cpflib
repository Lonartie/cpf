         }

         skip_rule parse_skip_rule() {
            expect_keyword("skip");
            skip_rule parsed_rule;
            parsed_rule.line = line_;
            parsed_rule.identifier = parse_identifier();
            current_rule_ = parsed_rule.identifier;
            expect("->");
